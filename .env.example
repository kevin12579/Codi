# ===========================
# 코디(Code AI) 환경변수 템플릿
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.example .env
# .env 파일은 절대 Git에 올리지 않습니다
# ===========================
#
# [설정 경계 — v0.9 §8-4, D20]  ※ 면접/심사 대비 핵심
#  ① 인프라/부팅 시크릿(아래 변수들) = .env 로만 주입, 대시보드 UI 비노출.
#     - 서버 신뢰의 뿌리(WEBHOOK_SECRET·JWT_SECRET·AES_SECRET_KEY·DB·REDIS).
#       UI에서 바꾸게 하면 그 화면이 뚫리는 순간 서버 전체가 털린다.
#  ② 런타임 커넥터 값(AI 키·Slack/Discord Webhook 등) = 대시보드 커넥터 탭 → DB(AES-256) 저장이 권장 경로.
#       .env 의 AI 키/Slack URL 은 V1 편의용 시드일 뿐, 운영은 UI 입력을 권장.
# ===========================

# Database
DB_USER=codeai
DB_PASSWORD=codeai1234
DB_NAME=codeai

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Claude API (https://console.anthropic.com 에서 발급)
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxx

# AI 엔진 다중화 (Phase 4) — 미사용 시 빈값으로 둬도 기동됨
# OpenAI GPT-4o (https://platform.openai.com)
OPENAI_API_KEY=
# Google Gemini 1.5 Flash (https://aistudio.google.com)
GEMINI_API_KEY=

# 커넥터 API 키 AES-256 암호화용 시크릿 (Phase 5) — 32바이트 권장
AES_SECRET_KEY=

# Playwright 전용 컨테이너 (Phase 3) — 기본값 있으므로 보통 그대로 둠
PLAYWRIGHT_SERVER_URL=http://playwright-server:3001
FRONTEND_URL=http://frontend:80

# GitHub Personal Access Token (repo 권한 필요)
GITHUB_TOKEN=ghp_xxxxxxxx

# Slack Incoming Webhook URL (Slack App 생성 후 발급) — ② 커넥터 값(운영은 대시보드 입력 권장)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Discord Incoming Webhook URL (v0.9 V1-B 도전 — 2번째 알림 채널)
# 운영 권장 경로: 대시보드 커넥터(notify)에서 discord 선택 + webhookUrl 입력 → DB 저장
DISCORD_WEBHOOK_URL=

# 코디(Code AI) 내부 API Key (임의 문자열로 설정)
CODEAI_API_KEY=codeai-local-key-12345

# Webhook HMAC Secret (GitHub Webhook 설정할 때 입력한 값과 동일하게)
WEBHOOK_SECRET=hcby0i1v6lk8ns2qtg5amr9u3fdxejz4


# JWT Secret
JWT_SECRET=codeai-jwt-secret-key-must-be-at-least-256-bits-long-for-security

# Spring Profile
SPRING_PROFILES_ACTIVE=local

# Playwright E2E 테스트 (P3: 전용 컨테이너 HTTP 호출 방식)
# false(기본): 테스트 스킵 후 PASSED 처리 (playwright-server 미기동 환경)
# true: playwright-server(:3001)로 실제 실행 — docker compose 로 playwright-server 기동 필요
PLAYWRIGHT_ENABLED=false
# PLAYWRIGHT_TIMEOUT_MS=300000   # 5분 (기본값)
GEMINI_MODEL=gemini-2.0-flash