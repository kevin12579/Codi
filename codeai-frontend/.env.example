# ===========================
# 코디(Code AI) 프론트엔드 환경변수 템플릿
# cp .env.example .env 후 사용
# VITE_ prefix 가 있어야 클라이언트에서 접근 가능
# ===========================

VITE_API_URL=http://localhost:8080
VITE_CODEAI_API_KEY=codeai-local-key-12345

# 로컬 테스트 및 커넥터 탭 활성화 설정
PLAYWRIGHT_USE_DOCKER=true
VITE_API_ENABLED=true